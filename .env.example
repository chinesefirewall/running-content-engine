# Copy this file to .env and fill in the values you need. .env itself is
# git-ignored -- never commit real keys. This file only documents what
# scripts/enrich_notes.py looks for; nothing in this project loads .env
# automatically, export these in your shell (or use `direnv`/`set -a`)
# before running the scripts.
#
# A ChatGPT Plus or Claude Pro subscription does NOT include API access.
# These need separate API keys, billed per token independently of those
# subscriptions. See docs/ai-content-enrichment.md.

# Required for: python scripts/enrich_notes.py --provider claude (the default)
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Required for: python scripts/enrich_notes.py --provider openai
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional for: python scripts/enrich_notes.py --provider ollama
# Only needed if your local Ollama server isn't at the default address.
# No key required -- this provider is fully local.
OLLAMA_HOST=http://localhost:11434
